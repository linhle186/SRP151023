# =====================================================================
# SHARED 10X WHITELISTS
# =====================================================================

rule download_whitelists:
    output:
        v2 = WHITELIST_V2,
        v3 = WHITELIST_V3
    params:
        url_v2 = "https://raw.githubusercontent.com/10XGenomics/cellranger/master/lib/python/cellranger/barcodes/737K-august-2016.txt",
        url_v3 = "https://raw.githubusercontent.com/10XGenomics/cellranger/master/lib/python/cellranger/barcodes/3M-february-2018.txt"
    shell:
        """
        mkdir -p $(dirname {output.v2})
        wget -q -O {output.v2} '{params.url_v2}'
        wget -q -O {output.v3} '{params.url_v3}'
        """